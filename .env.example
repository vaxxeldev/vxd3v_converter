BOT_TOKEN=123456789:replace-me
DATABASE_PATH=/app/data/bot.sqlite3
TEMP_ROOT=/tmp/vxd3v-converter
CACHE_ROOT=/app/data/cache
BANNER_ROOT=/usr/src/app/banners
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
RLOTTIE_RENDERER_BIN=/usr/local/bin/tgs-renderer
FONT_FILE=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
MONTSERRAT_FONT_FILE=/usr/share/fonts/truetype/vxd3v/Montserrat-Regular.ttf
SPACE_MONO_FONT_FILE=/usr/share/fonts/truetype/vxd3v/SpaceMono-Regular.ttf
LOG_LEVEL=INFO
MAX_INPUT_BYTES=20971520
MAX_OUTPUT_BYTES=51380224
MAX_RENDER_SECONDS=120
MAX_CONCURRENT_RENDERS=1
MAX_QUEUE_SIZE=20
MAX_CACHE_BYTES=536870912
ENABLE_CUSTOM_BUTTON_EMOJI=true
ADMIN_ID=123456789
RENDER_PRICE_KOPECKS=1000
MIN_TOPUP_KOPECKS=1000
NEW_USER_BONUS_KOPECKS=1000
DIRECT_PAYMENT_BANK=Bank name
DIRECT_PAYMENT_REQUISITES=payment details
DIRECT_PAYMENT_RECIPIENT=Recipient name
